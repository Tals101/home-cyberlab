  "test:ui": "playwright test --ui",
  "test:accessibility": "playwright test -g \"Accessibility Tests\" --project=chromium",
  "test:visual": "playwright test -g \"dashboard page matches visual snapshot\" --project=chromium",
  "test:visual:update": "playwright test -g \"dashboard page matches visual snapshot\" --project=chromium --update-snapshots",
  "report": "playwright show-report"
},
